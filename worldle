        function latLonToVector3(lat, lon, radius) {
            const phi = (90 - lat) * (Math.PI / 180);
            const theta = (lon + 180) * (Math.PI / 180);
            const x = -radius * Math.sin(phi) * Math.cos(theta);
            const y = radius * Math.cos(phi);
            const z = radius * Math.sin(phi) * Math.sin(theta);
            return new THREE.Vector3(x, y, z);
        }

        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371;
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                      Math.sin(dLon / 2) * Math.sin(dLon / 2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
            return Math.round(R * c);
        }

        function startGame() {
            const countryNames = Object.keys(countries);
            gameState.target = countryNames[Math.floor(Math.random() * countryNames.length)];
            gameState.guesses = [];
            gameState.markers.forEach(marker => scene.remove(marker));
            gameState.markers = [];
            
            document.getElementById("targetName").textContent = "???";
            document.getElementById("guessCount").textContent = "0";
            document.getElementById("guesses").innerHTML = "";
            document.getElementById("feedback").textContent = "";
            document.getElementById("countryGuess").value = "";
            document.getElementById("countryGuess").focus();
        }

        function makeGuess() {
            const guess = document.getElementById("countryGuess").value.trim();
            document.getElementById("countryGuess").value = "";

            if (!guess) return;

            const guessKey = Object.keys(countries).find(key => key.toLowerCase() === guess.toLowerCase());
            
            if (!guessKey) {
                document.getElementById("feedback").textContent = "❌ Country not found in database!";
                return;
            }

            if (gameState.guesses.includes(guessKey)) {
                document.getElementById("feedback").textContent = "⚠️ Already guessed this!";
                return;
            }

            gameState.guesses.push(guessKey);

            const targetPos = latLonToVector3(countries[gameState.target].lat, countries[gameState.target].lon, 1);
            const guessPos = latLonToVector3(countries[guessKey].lat, countries[guessKey].lon, 1);
            const distance = targetPos.distanceTo(guessPos);
            const kmDistance = calculateDistance(
                countries[gameState.target].lat, countries[gameState.target].lon,
                countries[guessKey].lat, countries[guessKey].lon
            );

            let color, feedback;
            if (guessKey === gameState.target) {
                color = 0x00ff00;
                feedback = `✅ CORRECT! It was ${gameState.target}!`;
                document.getElementById("targetName").textContent = gameState.target;
            } else if (distance < 0.3) {
                color = 0xff0000;
                feedback = `🔥 Extremely close! (${kmDistance} km away)`;
            } else if (distance < 0.6) {
                color = 0xff6600;
                feedback = `🌡️ Very close! (${kmDistance} km away)`;
            } else if (distance < 1.0) {
                color = 0xffaa00;
                feedback = `🟠 Getting warmer! (${kmDistance} km away)`;
            } else if (distance < 1.5) {
                color = 0xffff00;
                feedback = `🟡 Somewhat close! (${kmDistance} km away)`;
            } else {
                color = 0x6699ff;
                feedback = `❄️ Cold! (${kmDistance} km away)`;
            }

            const marker = new THREE.Mesh(
                new THREE.SphereGeometry(0.04, 16, 16),
                new THREE.MeshBasicMaterial({ color: color })
            );
            marker.position.copy(guessPos);
            scene.add(marker);
            gameState.markers.push(marker);

            document.getElementById("guessCount").textContent = gameState.guesses.length;
            document.getElementById("feedback").textContent = feedback;
            
            const guessesList = document.getElementById("guesses");
            const guessItem = document.createElement("div");
            guessItem.className = "guess-item";
            guessItem.innerHTML = `${guessKey} <span class="distance-indicator" style="background: #${color.toString(16).padStart(6, '0')}"></span>`;
            guessesList.insertBefore(guessItem, guessesList.firstChild);

            if (guessKey === gameState.target) {
                setTimeout(() => alert(`🎉 You won in ${gameState.guesses.length} guess(es)!`), 100);
            }

            document.getElementById("countryGuess").focus();
        }

        function resetGame() {
            startGame();
        }

        document.getElementById("countryGuess").addEventListener("keypress", (e) => {
            if (e.key === "Enter") makeGuess();
        });

        window.addEventListener("resize", () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        function animate() {
            requestAnimationFrame(animate);
            renderer.render(scene, camera);
        }

        startGame();
        animate();
