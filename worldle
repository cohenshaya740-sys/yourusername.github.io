<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Globle-Style Game</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body { 
            overflow: hidden; 
            background: #000033; 
            font-family: Arial, sans-serif; 
            color: white;
            height: 100vh;
        }
        
        canvas { display: block; }
        
        #ui {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            text-align: center;
            z-index: 10;
        }
        
        #gameInfo {
            background: rgba(0, 0, 51, 0.9);
            padding: 15px 25px;
            border-radius: 8px;
            margin-bottom: 15px;
            border: 2px solid #0066ff;
        }
        
        #gameInfo h2 {
            margin-bottom: 10px;
            font-size: 18px;
        }
        
        #stats {
            display: flex;
            gap: 30px;
            justify-content: center;
            font-size: 14px;
            margin-bottom: 10px;
        }
        
        #guessBox {
            background: rgba(0, 0, 51, 0.9);
            padding: 15px;
            border-radius: 8px;
            border: 2px solid #0066ff;
        }
        
        input {
            padding: 10px;
            font-size: 16px;
            width: 250px;
            border: 1px solid #0066ff;
            background: #000033;
            color: white;
            border-radius: 4px;
        }
        
        input::placeholder { color: #6699ff; }
        
        button {
            padding: 10px 20px;
            font-size: 16px;
            margin-left: 5px;
            background: #0066ff;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            transition: background 0.3s;
        }
        
        button:hover { background: #0052cc; }
        button:active { transform: scale(0.98); }
        
        #feedback {
            margin-top: 10px;
            font-size: 14px;
            height: 20px;
            color: #ffaa00;
        }
        
        #guessList {
            position: absolute;
            bottom: 20px;
            left: 20px;
            background: rgba(0, 0, 51, 0.9);
            padding: 15px;
            border-radius: 8px;
            border: 2px solid #0066ff;
            max-height: 300px;
            overflow-y: auto;
            max-width: 300px;
        }
        
        .guess-item {
            padding: 5px 0;
            font-size: 13px;
            border-bottom: 1px solid #0066ff;
        }
        
        .guess-item:last-child { border-bottom: none; }
        
        .distance-indicator {
            display: inline-block;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            margin-left: 10px;
            vertical-align: middle;
        }
    </style>
</head>
